{
  "providers": {
    "custom": {
      "apiKey": "my-secret-qwen-key",
      "apiBase": "http://localhost:42005/v1"
    }
  },
  "agents": {
    "defaults": {
      "model": "coder-model",
      "provider": "custom",
      "timezone": "UTC"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "allow_from": ["*"],
      "host": "0.0.0.0",
      "port": 8765
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://backend:8000",
          "NANOBOT_LMS_API_KEY": "my-secret-api-key"
        }
      }
    }
  }
}
